{
  "name": "pura-estate",
  "version": "1.0.0",
  "description": "PuraEstate - Premium Real Estate Platform",
  "private": true,
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "build": "eas build",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "submit": "eas submit",
    "build:web": "expo export:web",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "dev": "expo start",
    "eject": "expo eject",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-camera-roll/camera-roll": "^7.4.0",
    "@react-native-firebase/app": "^18.8.0",
    "@react-native-firebase/auth": "^18.8.0",
    "@react-native-firebase/database": "^18.8.0",
    "@react-native-firebase/firestore": "^18.8.0",
    "@react-native-firebase/storage": "^18.8.0",
    "@react-native-firebase/messaging": "^18.8.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.10",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.20",
    "@reduxjs/toolkit": "^1.9.7",
    "@stripe/stripe-react-native": "^11.11.0",
    "axios": "^1.6.5",
    "expo": "^51.0.8",
    "expo-blur": "^12.8.0",
    "expo-camera": "^14.1.0",
    "expo-clipboard": "^5.0.0",
    "expo-constants": "^15.4.0",
    "expo-document-picker": "^11.5.0",
    "expo-file-system": "^16.0.0",
    "expo-image": "^1.11.0",
    "expo-image-picker": "^14.7.0",
    "expo-linear-gradient": "^12.8.0",
    "expo-linking": "^6.2.0",
    "expo-location": "^16.7.0",
    "expo-media-library": "^15.9.0",
    "expo-notifications": "^0.27.0",
    "expo-permissions": "^14.4.0",
    "expo-screen-orientation": "^6.1.0",
    "expo-screen-capture": "^5.1.0",
    "expo-sharing": "^13.0.0",
    "expo-splash-screen": "^0.26.4",
    "expo-status-bar": "^1.11.1",
    "expo-web-browser": "^12.8.0",
    "firebase": "^10.7.0",
    "lottie-react-native": "^6.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-gesture-handler": "^2.14.0",
    "react-native-image-crop-picker": "^0.41.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.12",
    "react-native-masked-text": "^1.13.0",
    "react-native-pager-view": "^6.2.3",
    "react-native-reanimated": "^3.6.1",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-snap-carousel": "^3.9.1",
    "react-native-svg": "^14.1.0",
    "react-native-tab-view": "^3.5.2",
    "react-native-toast-message": "^2.2.0",
    "react-redux": "^8.1.3",
    "redux": "^4.2.1",
    "redux-persist": "^6.0.0",
    "redux-saga": "^1.2.3",
    "zustand": "^4.4.1",
    "date-fns": "^3.0.0",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native/metro-config": "^0.74.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.8",
    "@types/lodash": "^4.14.202",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "@types/redux-mock-store": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "babel-plugin-react-native-reanimated": "^3.6.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-native": "^4.1.1",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "metro-react-native-babel-preset": "^0.77.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.1.1",
    "redux-mock-store": "^1.5.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "resolutions": {
    "lodash": "^4.17.21",
    "minimist": "^1.2.8"
  },
  "expo": {
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/firestore",
      "@react-native-firebase/storage",
      "@react-native-firebase/messaging",
      "@stripe/stripe-react-native",
      "@react-native-async-storage/async-storage",
      "@react-native-camera-roll/camera-roll"
    ]
  }
}
