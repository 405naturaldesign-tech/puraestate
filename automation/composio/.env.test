# Test Environment Configuration
NODE_ENV=test
LOG_LEVEL=error
PORT=3001

# Composio
COMPOSIO_API_KEY=test-key-12345
COMPOSIO_BASE_URL=https://api.composio.dev
COMPOSIO_RETRY_ATTEMPTS=3
COMPOSIO_RETRY_DELAY_MS=1000

# WhatsApp
WHATSAPP_BUSINESS_ACCOUNT_ID=test-business-id
WHATSAPP_PHONE_NUMBER_ID=test-phone-id
WHATSAPP_RATE_LIMIT_PER_MINUTE=60

# Database
MONGODB_URI=mongodb://localhost:27017/puraestatecomposio-test
DB_NAME=puraestatecomposio-test

# Redis
REDIS_URL=redis://localhost:6379/1
REDIS_PREFIX=puraestatecomposio-test:

# Queue
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3
QUEUE_BACKOFF_DELAY=500

# Security
JWT_SECRET=test-jwt-secret-key-12345
ENCRYPTION_KEY=test-encryption-key-32-chars-1234567890
WEBHOOK_SECRET=test-webhook-secret-key-12345

# Webhook
WEBHOOK_URL=http://localhost:3001/webhooks

# Compliance
GDPR_RETENTION_DAYS=30
CCPA_ENABLED=true

# Analytics
ANALYTICS_ENABLED=false
SENTRY_DSN=

# Admin
ADMIN_USERNAME=test-admin
ADMIN_PASSWORD=testadmin123

# Testing
TEST_PHONE_NUMBER=+1234567890
TEST_INVESTOR_ID=investor-test-123
TEST_AGENT_ID=agent-test-123

# Firebase (Test)
FIREBASE_API_KEY=test-firebase-key
FIREBASE_AUTH_DOMAIN=test-project.firebaseapp.com
FIREBASE_PROJECT_ID=test-project
FIREBASE_STORAGE_BUCKET=test-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Payment (Stripe Test Mode)
STRIPE_PUBLIC_KEY=pk_test_123456789
STRIPE_SECRET_KEY=sk_test_123456789

# API Endpoints (Test)
API_BASE_URL=http://localhost:3001/api
SOCKET_URL=http://localhost:3001

# Test Data
ENABLE_MOCK_DATA=true
MOCK_DATA_SEED=test-seed-12345
