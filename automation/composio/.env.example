# Composio Configuration
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_BASE_URL=https://api.composio.dev

# WhatsApp Configuration
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Database
MONGODB_URI=mongodb://localhost:27017/puraestatecomposio
DB_NAME=puraestatecomposio

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=puraestatecomposio:

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Rate Limiting
WHATSAPP_RATE_LIMIT_PER_MINUTE=60
COMPOSIO_RETRY_ATTEMPTS=3
COMPOSIO_RETRY_DELAY_MS=1000

# Message Queue
QUEUE_CONCURRENCY=10
QUEUE_ATTEMPTS=5
QUEUE_BACKOFF_DELAY=2000

# Webhook
WEBHOOK_URL=http://localhost:3000/webhooks
WEBHOOK_SECRET=your_webhook_secret

# Security
JWT_SECRET=your_jwt_secret
ENCRYPTION_KEY=your_encryption_key_32_chars_long

# Compliance
GDPR_RETENTION_DAYS=90
CCPA_ENABLED=true

# Analytics
ANALYTICS_ENABLED=true
SENTRY_DSN=

# Admin Dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Testing
TEST_PHONE_NUMBER=+1234567890
TEST_INVESTOR_ID=test_investor_001
TEST_AGENT_ID=test_agent_001
