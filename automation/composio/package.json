{
  "name": "puraestatecomposio-whatsapp",
  "version": "1.0.0",
  "description": "Production-ready Composio WhatsApp automation integration for PuraEstate",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=\"(config|logger)\"",
    "test:integration": "jest --testPathPattern=\"integration\"",
    "test:e2e": "jest --testPathPattern=\"e2e\"",
    "test:security": "jest --testPathPattern=\"security\"",
    "test:performance": "jest --testPathPattern=\"performance\"",
    "test:ci": "jest --coverage --testTimeout=30000",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "migrate": "tsx src/db/migrations.ts",
    "seed:dev": "tsx scripts/seed-dev-data.ts",
    "seed:reset": "tsx scripts/reset-database.ts",
    "seed:properties": "tsx scripts/seed-properties.ts",
    "coverage:report": "jest --coverage && open coverage/lcov-report/index.html"
  },
  "dependencies": {
    "@composio/core": "^0.4.0",
    "@anthropic-ai/sdk": "^0.28.0",
    "express": "^4.18.2",
    "bull": "^4.11.3",
    "redis": "^4.6.7",
    "mongoose": "^7.5.0",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "joi": "^17.10.0",
    "axios": "^1.5.0",
    "node-cache": "^5.1.2",
    "firebase-admin": "^12.0.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.1.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.5.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.1.6",
    "tsx": "^3.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "@testing-library/jest-dom": "^6.1.4",
    "mongodb-memory-server": "^9.1.6",
    "supertest": "^6.3.3",
    "@types/supertest": "^2.0.12",
    "jest-junit": "^16.0.0",
    "nyc": "^15.1.0",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "prettier": "^3.0.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "puraestatecomposio",
    "whatsapp",
    "composio",
    "automation",
    "real-estate",
    "integration"
  ],
  "author": "PuraEstate Team",
  "license": "MIT"
}
