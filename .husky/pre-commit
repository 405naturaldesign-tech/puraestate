#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=false

# 1. Check for console.log statements (excluding console.warn and console.error)
echo "📋 Checking for console.log statements..."
if git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx)$' | xargs grep -l "console\.log\s*(" 2>/dev/null; then
  echo -e "${RED}❌ Found console.log statements in staged files${NC}"
  FAILED=true
else
  echo -e "${GREEN}✓ No console.log statements found${NC}"
fi

# 2. Check for hardcoded secrets/API keys
echo "🔐 Checking for hardcoded secrets..."
SECRETS_PATTERN="(api_key|apiKey|API_KEY|password|secret|token|PRIVATE_KEY|CREDENTIALS|AWS_SECRET)"
if git diff --cached --name-only --diff-filter=ACM | xargs grep -i -E "^\s*(const|let|var|export)\s+\w*($SECRETS_PATTERN)\w*\s*=" 2>/dev/null | grep -v ".env" | grep -v "example\|demo\|test"; then
  echo -e "${YELLOW}⚠️  Possible hardcoded secrets detected - please review${NC}"
  # Don't fail for this one, just warn
else
  echo -e "${GREEN}✓ No obvious hardcoded secrets found${NC}"
fi

# 3. Check for TODO/FIXME without issue numbers
echo "📝 Checking for TODO/FIXME comments..."
if git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|md)$' | xargs grep -E "TODO|FIXME" 2>/dev/null | grep -v "#[0-9]" | grep -v "<!-- " | head -20; then
  echo -e "${YELLOW}⚠️  Found TODO/FIXME comments without issue numbers${NC}"
  # Warning only, not failing
else
  echo -e "${GREEN}✓ All TODO/FIXME comments appear to have issue numbers${NC}"
fi

# 4. Check for large files (> 1MB)
echo "📦 Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | while read file; do
  if [ -f "$file" ]; then
    SIZE=$(stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null)
    if [ "$SIZE" -gt 1048576 ]; then
      echo "$file ($((SIZE / 1048576))MB)"
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo -e "${YELLOW}⚠️  Large files detected:${NC}"
  echo "$LARGE_FILES"
else
  echo -e "${GREEN}✓ No files larger than 1MB${NC}"
fi

# 5. ESLint check (fail on errors only, not warnings)
echo "🔎 Running ESLint..."
if npm run lint -- --fix --max-warnings=0 2>&1 | grep -q "error"; then
  echo -e "${RED}❌ ESLint check failed${NC}"
  FAILED=true
else
  echo -e "${GREEN}✓ ESLint passed${NC}"
fi

# 6. Prettier format check
echo "🎨 Checking code formatting with Prettier..."
if npm run format:check 2>&1; then
  echo -e "${GREEN}✓ Code formatting is correct${NC}"
else
  echo -e "${YELLOW}⚠️  Some files need formatting. Running prettier --write...${NC}"
  npm run format
  git add -A
fi

# 7. TypeScript type check
echo "📘 Running TypeScript type check..."
if npm run type-check 2>&1; then
  echo -e "${GREEN}✓ TypeScript types are correct${NC}"
else
  echo -e "${RED}❌ TypeScript type check failed${NC}"
  FAILED=true
fi

# 8. Conventional commits validation
echo "📌 Validating commit message format..."
COMMIT_MSG_FILE="${1:-.git/COMMIT_EDITMSG}"
if [ -f "$COMMIT_MSG_FILE" ]; then
  FIRST_LINE=$(head -n 1 "$COMMIT_MSG_FILE")
  if echo "$FIRST_LINE" | grep -qE "^(feat|fix|docs|test|refactor|style|chore|ci|perf)(\(.+\))?: .{1,}"; then
    echo -e "${GREEN}✓ Commit message follows conventional commits${NC}"
  else
    echo -e "${YELLOW}⚠️  Commit message may not follow conventional commits format${NC}"
    echo "Expected format: feat|fix|docs|test|refactor|style|chore(scope): description"
  fi
fi

# Final result
echo ""
if [ "$FAILED" = true ]; then
  echo -e "${RED}❌ Pre-commit checks failed. Please fix the errors above.${NC}"
  exit 1
else
  echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
  exit 0
fi
