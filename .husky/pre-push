#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FAILED=false

# 1. Run full test suite
echo "🧪 Running test suite..."
if npm run test:ci 2>&1; then
  echo -e "${GREEN}✓ All tests passed${NC}"
else
  echo -e "${RED}❌ Tests failed${NC}"
  FAILED=true
fi

# 2. Run security checks (npm audit)
echo "🔒 Running security audit..."
if npm audit --audit-level=moderate 2>&1; then
  echo -e "${GREEN}✓ No critical security vulnerabilities found${NC}"
else
  # npm audit returns non-zero if vulnerabilities found, but we'll warn instead of fail for moderate
  AUDIT_OUTPUT=$(npm audit 2>&1)
  if echo "$AUDIT_OUTPUT" | grep -q "high\|critical"; then
    echo -e "${RED}❌ High or critical security vulnerabilities detected${NC}"
    FAILED=true
  else
    echo -e "${YELLOW}⚠️  Some moderate vulnerabilities detected. Review before pushing.${NC}"
  fi
fi

# Final result
echo ""
if [ "$FAILED" = true ]; then
  echo -e "${RED}❌ Pre-push checks failed. Please fix the errors above.${NC}"
  exit 1
else
  echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
  exit 0
fi
