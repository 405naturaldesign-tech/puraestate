# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Cache Configuration
CACHE_TTL=86400
CACHE_ENABLED=true

# Cost Budget
DAILY_COST_BUDGET=100
COST_ALERT_THRESHOLD=0.80

# Matching Configuration
TOP_PROPERTIES_TO_SCORE=3
RANKING_BATCH_SIZE=100
ENABLE_FALLBACK=true

# API Configuration
API_MAX_RETRIES=3
API_TIMEOUT=30000

# Analytics
ANALYTICS_ENABLED=true
PERFORMANCE_TRACKING=true

# Database (Optional - for production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=real_estate
DB_USER=investor
DB_PASSWORD=

# Server Configuration (if running as service)
SERVER_PORT=3000
SERVER_HOST=0.0.0.0
