{
  "name": "property-matching-algorithm",
  "version": "1.0.0",
  "description": "Production-ready OpenRouter AI property matching algorithm for real estate investors",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:unit": "jest src/__tests__/unit",
    "test:integration": "jest src/__tests__/integration",
    "dev": "NODE_ENV=development node src/index.js",
