    "dotenv": "^16.0.0",
    "redis": "^4.6.0",
    "winston": "^3.11.0",
    "node-cache": "^5.1.2"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
