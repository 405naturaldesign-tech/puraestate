# =============================================================================
# PuraEstate – Production Secrets Template
# =============================================================================
# This file is a TEMPLATE. Replace every CHANGE_ME placeholder with real
# production values before deploying.
#
# Security rules:
#  1. NEVER commit this file with real secrets to version control.
#  2. Store the filled-in version in a secrets manager (Vault, AWS SSM, etc.).
#  3. On the VPS, deploy only to /home/deploy/puraestate/.env (chmod 600).
#  4. Rotate all secrets immediately if this file is ever exposed.
# =============================================================================

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
APP_VERSION=1.0.0
DOMAIN=puraestate.com

# ---------------------------------------------------------------------------
# Generate strong secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
# ---------------------------------------------------------------------------
SECRET_KEY=<run: python3 -c "import secrets; print(secrets.token_hex(64))">
JWT_SECRET_KEY=<run: python3 -c "import secrets; print(secrets.token_hex(64))">

# ---------------------------------------------------------------------------
# PostgreSQL
# Use a strong unique password (min 32 chars, mixed case + symbols).
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# ---------------------------------------------------------------------------
POSTGRES_DB=puraestate_prod
POSTGRES_USER=puraestate
POSTGRES_PASSWORD=<strong-password-here>

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=<strong-password-here>

# ---------------------------------------------------------------------------
# Flask Workers (2 * nproc + 1 is a good starting point)
# ---------------------------------------------------------------------------
FLASK_WORKERS=5
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# ---------------------------------------------------------------------------
# Celery / Flower
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=4
FLOWER_USER=admin
FLOWER_PASSWORD=<strong-password-here>

# ---------------------------------------------------------------------------
# Email – SendGrid (recommended for transactional email)
# Create API key at: https://app.sendgrid.com/settings/api_keys
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=<sendgrid-api-key>
MAIL_DEFAULT_SENDER=noreply@puraestate.com
SENDGRID_API_KEY=<sendgrid-api-key>

# ---------------------------------------------------------------------------
# AWS S3 (media/image storage)
# IAM user should have ONLY s3:PutObject, s3:GetObject, s3:DeleteObject
# on the specific bucket. Never use root credentials.
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=<aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<aws-secret-access-key>
AWS_S3_BUCKET=puraestate-media-prod
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Stripe (billing)
# Get keys from: https://dashboard.stripe.com/apikeys
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_<key>
STRIPE_PUBLISHABLE_KEY=pk_live_<key>
STRIPE_WEBHOOK_SECRET=whsec_<webhook-signing-secret>

# ---------------------------------------------------------------------------
# Google Maps
# Restrict the key to your domain in GCP console.
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=<api-key>

# ---------------------------------------------------------------------------
# Mapbox
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=<mapbox-public-token>

# ---------------------------------------------------------------------------
# n8n
# ---------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=<run: python3 -c "import secrets; print(secrets.token_hex(16))">
N8N_POSTGRES_DB=puraestate_n8n
N8N_USER=admin
N8N_PASSWORD=<strong-password-here>

# ---------------------------------------------------------------------------
# Let's Encrypt
# ---------------------------------------------------------------------------
LETSENCRYPT_EMAIL=devops@puraestate.com
