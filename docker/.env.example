# =============================================================================
# PuraEstate Docker Compose – Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit the populated .env to version control.
#
# The .env.production file is a separate secrets template for CI/CD pipelines.
# =============================================================================

# ---------------------------------------------------------------------------
# Application version tag (used for Docker image tags)
# ---------------------------------------------------------------------------
APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Domain & URLs
# ---------------------------------------------------------------------------
DOMAIN=puraestate.com
SITE_URL=https://puraestate.com
API_URL=https://puraestate.com

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=puraestate_prod
POSTGRES_USER=puraestate
POSTGRES_PASSWORD=CHANGE_ME_STRONG_POSTGRES_PASSWORD

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# ---------------------------------------------------------------------------
# Flask Application Secrets
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_64_CHARACTER_RANDOM_HEX_STRING
JWT_SECRET_KEY=CHANGE_ME_64_CHARACTER_RANDOM_HEX_STRING_JWT

# JWT Token lifetimes
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# ---------------------------------------------------------------------------
# Flask Worker Configuration
# ---------------------------------------------------------------------------
# Number of Gunicorn workers (rule: 2 * CPU_CORES + 1)
FLASK_WORKERS=5

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_CONCURRENCY=4

# ---------------------------------------------------------------------------
# Flower (Celery monitoring)
# ---------------------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME_FLOWER_PASSWORD

# ---------------------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------------------
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=CHANGE_ME_SENDGRID_API_KEY
MAIL_DEFAULT_SENDER=noreply@puraestate.com

# ---------------------------------------------------------------------------
# SendGrid
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=CHANGE_ME_SENDGRID_KEY

# ---------------------------------------------------------------------------
# AWS S3 (property image storage)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET
AWS_S3_BUCKET=puraestate-media
AWS_REGION=us-east-1

# ---------------------------------------------------------------------------
# Stripe (subscription billing)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ---------------------------------------------------------------------------
# Google Maps
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=CHANGE_ME_GOOGLE_MAPS_KEY

# ---------------------------------------------------------------------------
# Mapbox (Next.js frontend map)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=CHANGE_ME_MAPBOX_TOKEN

# ---------------------------------------------------------------------------
# n8n Workflow Automation (optional)
# ---------------------------------------------------------------------------
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHARACTER_N8N_KEY
N8N_POSTGRES_DB=puraestate_n8n
N8N_USER=admin
N8N_PASSWORD=CHANGE_ME_N8N_PASSWORD

# ---------------------------------------------------------------------------
# Let's Encrypt
# ---------------------------------------------------------------------------
LETSENCRYPT_EMAIL=devops@puraestate.com
