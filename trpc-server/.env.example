# TRPC Server Config
NODE_ENV=development
PORT=3000
TRPC_BASE_URL=http://localhost:3000

# Flask Backend Gateway
FLASK_API_URL=http://localhost:5000
FLASK_API_KEY=your_api_key_here

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Redis Cache
REDIS_URL=redis://localhost:6379

# Composio Integration
COMPOSIO_API_KEY=your_composio_api_key
COMPOSIO_BASE_URL=https://backend.composio.dev/api/v2

# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Supabase (for real-time subscriptions)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# CORS
CORS_ORIGIN=exp://localhost:8081,http://localhost:8081

# Logging
LOG_LEVEL=debug
