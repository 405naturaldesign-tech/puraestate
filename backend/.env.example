# ============================================================
# Costa Rica Real Estate SaaS Platform - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Flask
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=super-secret-key-change-me

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cr_realestate_dev
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cr_realestate_test

# JWT
JWT_SECRET_KEY=jwt-super-secret-key-change-me
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_DAYS=30

# Redis
REDIS_URL=redis://localhost:6379/0
TEST_REDIS_URL=redis://localhost:6379/15

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File uploads
UPLOAD_FOLDER=/tmp/uploads

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@costaricarealestate.com

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=cr-realestate-media
AWS_REGION=us-east-1

# Google Maps
GOOGLE_MAPS_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# SendGrid
SENDGRID_API_KEY=

# Logging
LOG_LEVEL=DEBUG
